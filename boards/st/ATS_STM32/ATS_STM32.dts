/dts-v1/;
/* Base STM32H753 SoC description. */
#include <st/h7/stm32h753Xi.dtsi>
/* STM32H753 pinmux labels used by pinctrl-0 entries below. */
#include <st/h7/stm32h753vitx-pinctrl.dtsi>
/* STM32 pinmux helper macros used for custom SPI4 pin definitions below. */
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>

/ {
	/* Human-readable board identification shown in generated metadata. */
	model = "ATS STM32H753 Board";
	/* Board-specific compatible, followed by the STM32H753VI SoC family. */
	compatible = "vnd,ats-stm32", "st,stm32h753vi";

	/* Default system resources Zephyr should bind to at boot. */
	chosen {
		/* UART used for printk/logging output. */
		zephyr,console = &usart1;
		/* UART used by the Zephyr shell, if enabled. */
		zephyr,shell-uart = &usart1;
		/* Main SRAM region used for runtime allocations and data. */
		zephyr,sram = &sram0;
		/* On-chip flash used for the application image. */
		zephyr,flash = &flash0;
		/* Default CAN controller for application code and samples. */
		zephyr,canbus = &fdcan1;
	};

	/*
	 * Convenience aliases for the three external SPI ADCs and the hall-effect
	 * interrupt line.
	 * Assumption: no separate CS pin was provided, so each ADC is the only
	 * device on its SPI bus and chip select is handled externally in hardware.
	 */
	aliases {
		adc-spi1 = &ADC_1;
		adc-spi2 = &ADC_2;
		adc-spi3 = &ADC_3;
		adc1-disable = &adc1_disable;
		adc2-disable = &adc2_disable;
		adc3-disable = &adc3_disable;
		i2c-irq = &HallEffect_1;
	};

	/* Named board-level GPIO resources that application code can look up. */
	board_signals {
		/*
		 * ADC disable lines are active high.
		 * External pull-ups on the board keep the ADCs disabled until firmware
		 * actively drives these lines low.
		 */
		adc1_disable: adc1-disable {
			gpios = <&gpiod 2 GPIO_ACTIVE_HIGH>;
			label = "ADC1 Disable";
		};

		adc2_disable: adc2-disable {
			gpios = <&gpiod 4 GPIO_ACTIVE_HIGH>;
			label = "ADC2 Disable";
		};

		adc3_disable: adc3-disable {
			gpios = <&gpioc 13 GPIO_ACTIVE_HIGH>;
			label = "ADC3 Disable";
		};

		/* Hall-effect sensor interrupt line on PE1. */
		HallEffect_1: hall-effect-1 {
			gpios = <&gpioe 1 GPIO_ACTIVE_LOW>;
			label = "Hall Effect 1";
		};
	};
};

/* External high-speed clock source feeding the PLLs. */
&clk_hse {
	clock-frequency = <DT_FREQ_M(8)>;
	status = "okay";
};

/* Main PLL generates the 480 MHz system clock tree. */
&pll {
	div-m = <2>;
	mul-n = <240>;
	div-p = <2>;
	div-q = <2>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

/* Secondary PLL is used here to generate the FDCAN kernel clock. */
&pll2 {
	div-m = <4>;
	mul-n = <120>;
	div-p = <2>;
	div-q = <3>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

/* RCC selects the system clock source and bus prescalers. */
&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(480)>;
	d1cpre = <1>;
	hpre = <2>;
	d1ppre = <2>;
	d2ppre1 = <2>;
	d2ppre2 = <2>;
	d3ppre = <2>;
};

/* STM32H7 power configuration. "ldo" matches a typical direct LDO setup. */
&pwr {
	power-supply = "ldo";
};

/* Enable GPIO controller blocks so pins can be configured from application code. */
&gpioa { status = "okay"; };
&gpiob { status = "okay"; };
&gpioc { status = "okay"; };
&gpiod { status = "okay"; };
&gpioe { status = "okay"; };

/* Primary debug/logging UART routed to PA9/PA10. */
&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* CAN1 */
&fdcan1 {
	clocks = <&rcc STM32_CLOCK(APB1_2, 8)>,
		 <&rcc STM32_SRC_PLL2_Q FDCAN_SEL(2)>;
	pinctrl-0 = <&fdcan1_rx_pa11 &fdcan1_tx_pa12>;
	pinctrl-names = "default";
	/* 1 Mbit/s nominal bitrate with an 87.5% sample point. */
	bitrate = <1000000>;
	sample-point = <875>;
	status = "okay";
};

/* CAN2 */
&fdcan2 {
	clocks = <&rcc STM32_CLOCK(APB1_2, 9)>,
		 <&rcc STM32_SRC_PLL2_Q FDCAN_SEL(2)>;
	pinctrl-0 = <&fdcan2_rx_pb5 &fdcan2_tx_pb6>;
	pinctrl-names = "default";
	bitrate = <1000000>;
	sample-point = <875>;
	status = "okay";
};

/* I2C1 routed to PB8/PB9 for external peripherals. */
&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;
};

/*
 * DAC1 exposes two analog outputs on PA4 and PA5.
 * These pins are dedicated DAC outputs in the current firmware.
 */
&dac1 {
	pinctrl-0 = <&dac1_out1_pa4 &dac1_out2_pa5>;
	pinctrl-names = "default";
	status = "okay";
};

/* ADC1 SPI bus: PB15 MOSI, PB14 MISO, PB13 SCK. */
&spi2 {
	pinctrl-0 = <&spi2_sck_pb13 &spi2_miso_pb14 &spi2_mosi_pb15>;
	pinctrl-names = "default";
	status = "okay";

	/* AD7708 #1 control signals: PD8 DRDY, PB12 reset. */
	ADC_1: adc@0 {
		compatible = "adi,ad7708";
		reg = <0>;
		spi-max-frequency = <100000>;
		drdy-gpios = <&gpiod 8 GPIO_ACTIVE_LOW>;
		reset-gpios = <&gpiob 12 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

/* ADC2 SPI bus: PC12 MOSI, PC11 MISO, PC10 SCK. */
&spi3 {
	pinctrl-0 = <&spi3_sck_pc10 &spi3_miso_pc11 &spi3_mosi_pc12>;
	pinctrl-names = "default";
	status = "okay";

	/* AD7708 #2 control signals: PD0 DRDY, PD1 reset. */
	ADC_2: adc@0 {
		compatible = "adi,ad7708";
		reg = <0>;
		spi-max-frequency = <100000>;
		drdy-gpios = <&gpiod 0 GPIO_ACTIVE_LOW>;
		reset-gpios = <&gpiod 1 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

/* ADC3 SPI bus: PE6 MOSI, PE5 MISO, PE2 SCK. */
&spi4 {
	pinctrl-0 = <&spi4_sck_pe2 &spi4_miso_pe5 &spi4_mosi_pe6>;
	pinctrl-names = "default";
	status = "okay";

	/* AD7708 #3 control signals: PE3 DRDY, PE4 reset. */
	ADC_3: adc@0 {
		compatible = "adi,ad7708";
		reg = <0>;
		spi-max-frequency = <100000>;
		drdy-gpios = <&gpioe 3 GPIO_ACTIVE_LOW>;
		reset-gpios = <&gpioe 4 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

/* Custom pinctrl entries for SPI4 on GPIOE, since these pins are board-specific. */
&pinctrl {
	spi4_sck_pe2: spi4_sck_pe2 {
		pinmux = <STM32_PINMUX('E', 2, AF5)>;
	};

	spi4_miso_pe5: spi4_miso_pe5 {
		pinmux = <STM32_PINMUX('E', 5, AF5)>;
	};

	spi4_mosi_pe6: spi4_mosi_pe6 {
		pinmux = <STM32_PINMUX('E', 6, AF5)>;
	};
};
